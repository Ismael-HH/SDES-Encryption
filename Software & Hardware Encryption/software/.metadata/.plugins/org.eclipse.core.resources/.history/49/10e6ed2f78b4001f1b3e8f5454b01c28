#include <stdio.h>
#include "system.h"
#include "altera_avalon_pio_regs.h"
#include "FreeRTOS.h"
#include "task.h"
#include "timers.h"
#include "semphr.h"

#define QUEUE_LENGTH 5
#define QUEUE_ITEM_SIZE sizeof(int)

//button queue messages
#define KEYGEN 0
#define ENCRYPT 1
#define DECRYPT 2

//handle creations
SemaphoreHandle_t g_mutex;
QueueHandle_t messageQueue;

//delay constant
const TickType_t ms_slept = 500 / portTICK_PERIOD_MS;

// Define seven-segment hex patterns for 0-F
const int hex_patterns[16] = {
    0x01,
    0x4F,
    0x12,
    0x06,
    0x4C,
    0x24,
    0x20,
    0x0F,
    0x00,
    0x04,
    0x08,
    0x60,
    0x31,
    0x42,
    0x30,
    0x38
};

//Key Generation task
void vDisplayTask(void *pvParameters) {

	//task declearions
	int switchState;
	int keyData;
	int keyOne;
	int keyTwo;
	int keyOneHex5;
	int keyOneHex4;
	int keyTwoHex3;
	int keyTwoHex2;
	int hex5;
	int hex4;
	int hex3;
	int hex2;
	int hex1;
	int hex0;
	int encryptedHex1;
	int encryptedHex0;
	int encryptedData;
    int currentMessage = -1;
    int newMessage;

	while (1) {

        // Check if there's a new pattern in the queue
        if (xQueueReceive(messageQueue, &newMessage, 0) == pdTRUE)
        {
        	currentMessage = newMessage; // Update the current pattern
        }

        // Execute the current pattern
		switch (currentMessage)
		{
		case KEYGEN: {
        // Read the state of the switches
        switchState = IORD_ALTERA_AVALON_PIO_DATA(SWITCHES_BASE);

        // Write switch state to custom IP
        IOWR(CUSTOMIP_0_BASE, 0, switchState);

        // Read back the keys from the custom IP
        keyData = IORD(CUSTOMIP_0_BASE, 1); // Read from address 1
        keyOne = (keyData >> 8) & 0xFF;    // Extract keyOne (bits [15:8])
        keyTwo = keyData & 0xFF;           // Extract keyTwo (bits [7:0])

        // Extract individual nibbles for hexadecimal display
        keyOneHex5 = (keyOne >> 4) & 0xF; // Upper nibble of keyOne
        keyOneHex4 = keyOne & 0xF;        // Lower nibble of keyOne

        keyTwoHex3 = (keyTwo >> 4) & 0xF; // Upper nibble of keyTwo
        keyTwoHex2 = keyTwo & 0xF;        // Lower nibble of keyTwo

        // Map nibbles to seven-segment patterns
        hex5 = hex_patterns[keyOneHex5];
        hex4 = hex_patterns[keyOneHex4];
        hex3 = hex_patterns[keyTwoHex3];
        hex2 = hex_patterns[keyTwoHex2];

        // Write the patterns to the HEX displays
        IOWR_ALTERA_AVALON_PIO_DATA(HEX5_BASE, hex5);
        IOWR_ALTERA_AVALON_PIO_DATA(HEX4_BASE, hex4);
        IOWR_ALTERA_AVALON_PIO_DATA(HEX3_BASE, hex3);
        IOWR_ALTERA_AVALON_PIO_DATA(HEX2_BASE, hex2);

        break;
		}
        case ENCRYPT: {
            // Send data to the custom IP for encryption
            switchState = IORD_ALTERA_AVALON_PIO_DATA(SWITCHES_BASE) & 0xFF;
            IOWR(CUSTOMIP_0_BASE, 1, switchState);  // Write to address 1 to start encryption

            // Read back the encrypted data from the IP
            encryptedData = IORD(CUSTOMIP_0_BASE, 2); // Read encrypted data from address 2
            encryptedHex1 = (encryptedData >> 4) & 0xF;
            encryptedHex0 = (encryptedData) & 0xF;

            // Map encrypted nibbles to seven-segment patterns
            hex1 = hex_patterns[encryptedHex1];
            hex0 = hex_patterns[encryptedHex0];

            // Write the encrypted data to the HEX displays
            IOWR_ALTERA_AVALON_PIO_DATA(HEX5_BASE, hex1);
            IOWR_ALTERA_AVALON_PIO_DATA(HEX4_BASE, hex0);

        break;
        }

		default:
		            break;
		}
		// Delay to allow FreeRTOS to switch to other tasks (e.g., 100 ms)
        vTaskDelay(pdMS_TO_TICKS(100));
        currentMessage = -1;
    }
}

// Button check class
void ButtonTask(void *pvParameters)
{
    int message = 0xF;
    int buttonState;
    while (1)
    {
        // Read button inputs
        xSemaphoreTake(g_mutex, portMAX_DELAY);
        buttonState = IORD_ALTERA_AVALON_PIO_DATA(BUTTONS_BASE);

        if (buttonState == 0x7) // Button 0: key generation
        {
            message = KEYGEN;
        	xQueueSendToBack(messageQueue, &message, 10);

        }
        else if (buttonState == 0xB) { // Button 1: encryption
			message = ENCRYPT;
			xQueueSendToBack(messageQueue, &message, 10);
		}

        xSemaphoreGive(g_mutex);
        vTaskDelay(ms_slept); // Poll buttons periodically

    }
}

int main(){

    // Create semaphore
	g_mutex = xSemaphoreCreateMutex();


	if (pdFAIL == xTaskCreate(ButtonTask, "Button Task", configMINIMAL_STACK_SIZE, NULL, 1, NULL))
	{
		printf("Button task creation failed\n");
	}

	if (pdFAIL ==xTaskCreate(vDisplayTask,"Key Task", configMINIMAL_STACK_SIZE,NULL, 1, NULL))
	{
		printf("Key task creation failed\n");
	}

	messageQueue = xQueueCreate(QUEUE_LENGTH, QUEUE_ITEM_SIZE);
	// Start the FreeRTOS scheduler
	vTaskStartScheduler();

	while(1){}

}

